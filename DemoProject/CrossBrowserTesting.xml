<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserTesting">
  <test name="chrome Test">
  <parameter name="browser" value="chrome"></parameter>
    <classes>
      <class name="demoProject.LoginTest">
      <methods><include name="VerifytheUserValidCredentials"></include>
      <include name="VerifyLogout"/></methods>
      </class>
      <class name="demoProject.Login"/>
    </classes>
  </test> <!-- Test -->
  
  <test name="Edge Test">
  <parameter name="browser" value="Safari"></parameter>
    <classes>
      <class name="demoProject.LoginTest">
      <methods><include name="VerifytheUserValidCredentials"></include>
      <include name="VerifyLogout"/></methods>
      </class>
      <class name="demoProject.Login"/>
    </classes>
  </test> <!-- Test -->
  
</suite> <!-- Suite -->
